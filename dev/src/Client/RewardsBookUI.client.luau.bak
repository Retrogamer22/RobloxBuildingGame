-- Subtle floating animation on the book
task.spawn(function()
	local startY = BookHolder.Position.Y.Offset
	local t = 0
	while BookHolder and BookHolder.Parent do
		t = t + 0.03
		BookHolder.Position = UDim2.new(0.5, 0, 0, startY + math.sin(t) * 4)
		task.wait(0.03)
	end
end)

-- ============================================
-- OPEN / CLOSE
-- ============================================
local rewardsBlur = Instance.new("BlurEffect")
rewardsBlur.Name = "RewardsBookBlur"
rewardsBlur.Size = 0
rewardsBlur.Enabled = false
rewardsBlur.Parent = Lighting

-- UIs to hide while the rewards book is open (matches ShopUI's set)
local GAME_UIS_TO_HIDE = {
	"InventoryGui",
	"CrosshairGui",
	"MainMenuButtonGui",
	"CoinHUD",
	"RewardsBookButtonGui",
	"TipToastsGui",
	"MobileControlsGui",
	"LikesLeaderboardGui",
	"FeedbackUI",
	"ChatMonitorUI",
}

-- Roblox CoreGui elements to hide (built-in chat icon, etc.)
local CORE_GUIS_TO_HIDE = {
	Enum.CoreGuiType.Chat,
}

local function hideGameUIs()
	for _, name in ipairs(GAME_UIS_TO_HIDE) do
		local ui = PlayerGui:FindFirstChild(name)
		if ui then ui.Enabled = false end
	end
	for _, coreType in ipairs(CORE_GUIS_TO_HIDE) do
		pcall(function()
			StarterGui:SetCoreGuiEnabled(coreType, false)
		end)
	end
end

local function showGameUIs()
	for _, name in ipairs(GAME_UIS_TO_HIDE) do
		local ui = PlayerGui:FindFirstChild(name)
		if ui then ui.Enabled = true end
	end
	for _, coreType in ipairs(CORE_GUIS_TO_HIDE) do
		pcall(function()
			StarterGui:SetCoreGuiEnabled(coreType, true)
		end)
	end
end

local function openBook()
	if IsOpen then return end
	-- Block opening on title screen
	if _G.CameraController and _G.CameraController.IsGameStarted and not _G.CameraController.IsGameStarted() then return end
	-- Block opening if any other modal is up
	if _G.ShopUI and _G.ShopUI.IsOpen and _G.ShopUI.IsOpen() then return end
	if _G.DailyRewardsUI and _G.DailyRewardsUI.IsOpen and _G.DailyRewardsUI.IsOpen() then return end

	print("[RewardsBookUI] Opening")
	IsOpen = true

	hideGameUIs()

	rewardsBlur.Size = 0; rewardsBlur.Enabled = true
	TweenService:Create(rewardsBlur, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = 20,
	}):Play()

	local fullSize = Panel.Size
	local sx, sy = fullSize.X.Scale, fullSize.Y.Scale

	ScreenGui.Enabled = true
	Panel.Size = UDim2.new(sx * 0.85, 0, sy * 0.85, 0)
	Overlay.BackgroundTransparency = 1
	TweenService:Create(Panel, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = fullSize,
	}):Play()
	TweenService:Create(Overlay, TweenInfo.new(0.2), { BackgroundTransparency = 0.4 }):Play()
end

local function closeBook()
	if not IsOpen then return end
	print("[RewardsBookUI] Closing")
	IsOpen = false

	TweenService:Create(rewardsBlur, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = 0,
	}):Play()

	local fullSize = UDim2.new(IsMobile and 0.9 or 0.6, 0, IsMobile and 0.8 or 0.7, 0)
	local sx, sy = fullSize.X.Scale, fullSize.Y.Scale
	local tp = TweenService:Create(Panel, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.new(sx * 0.92, 0, sy * 0.92, 0),
	})
	local to = TweenService:Create(Overlay, TweenInfo.new(0.15), { BackgroundTransparency = 1 })
	tp:Play(); to:Play(); tp.Completed:Wait()
	ScreenGui.Enabled = false
	Panel.Size = fullSize
	rewardsBlur.Enabled = false

	showGameUIs()
end

local function toggleBook()
	if IsOpen then closeBook() else openBook() end
end

CloseBtn.MouseButton1Click:Connect(closeBook)

Overlay.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		closeBook()
	end
end)

-- Hotkey: B
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.B then
		local focused = UserInputService:GetFocusedTextBox()
		if focused then return end
		toggleBook()
	end
end)

-- Public API
_G.RewardsBookUI.Open = openBook
_G.RewardsBookUI.Close = closeBook
_G.RewardsBookUI.Toggle = toggleBook

print("[RewardsBookUI] Initialized — Open via book button or B key")
