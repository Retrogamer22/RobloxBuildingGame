--[[
	InventoryController
	Minecraft-style inventory with templates
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local BlockShapes = require(ReplicatedStorage:WaitForChild("BlockShapes"))

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- State
local CurrentSlot = 1
local CurrentRotation = 0
local InventoryOpen = false

-- Hotbar: each slot holds { ShapeId, Material, Color } or nil
local Hotbar = {}
for i = 1, 9 do
	Hotbar[i] = nil
end

-- Configuring block
local ConfiguringShape = nil
local ConfiguringMaterial = Enum.Material.Plastic
local ConfiguringColor = Color3.fromRGB(163, 162, 165)

-- UI References
local ScreenGui = nil
local HotbarFrame = nil
local SlotFrames = {}
local SelectionFrame = nil
local BlockNameLabel = nil
local InventoryPanel = nil
local CustomizerPanel = nil

--====================--
--    FUNCTIONS       --
--====================--

local function updateSelection()
	if SelectionFrame then
		local xPos = 8 + (CurrentSlot - 1) * 52
		TweenService:Create(SelectionFrame, TweenInfo.new(0.1), {
			Position = UDim2.new(0, xPos, 0.5, -26)
		}):Play()
	end
	
	local data = Hotbar[CurrentSlot]
	if BlockNameLabel then
		if data then
			local shape = BlockShapes.GetShape(data.ShapeId)
			BlockNameLabel.Text = shape and shape.Name or ""
		else
			BlockNameLabel.Text = "Empty"
		end
	end
end

local function selectSlot(slotNumber)
	CurrentSlot = slotNumber
	updateSelection()
end

local function updateHotbarSlot(slotNumber)
	local slot = SlotFrames[slotNumber]
	if not slot then return end
	
	local preview = slot:FindFirstChild("Preview")
	if not preview then return end
	
	local data = Hotbar[slotNumber]
	
	if data then
		preview.BackgroundTransparency = 0
		preview.BackgroundColor3 = data.Color
		
		if data.ShapeId == "Slab" then
			preview.Size = UDim2.new(0, 28, 0, 14)
		elseif data.ShapeId == "Stair" or data.ShapeId == "StairInnerCorner" or data.ShapeId == "StairOuterCorner" then
			preview.Size = UDim2.new(0, 28, 0, 20)
		else
			preview.Size = UDim2.new(0, 28, 0, 28)
		end
	else
		preview.BackgroundTransparency = 1
	end
end

local function updateCustomizerPreview()
	if not CustomizerPanel then return end
	
	local previewFrame = CustomizerPanel:FindFirstChild("PreviewFrame")
	if not previewFrame then return end
	
	local blockPreview = previewFrame:FindFirstChild("BlockPreview")
	if blockPreview then
		blockPreview.BackgroundColor3 = ConfiguringColor
		
		if ConfiguringShape == "Slab" then
			blockPreview.Size = UDim2.new(0, 40, 0, 20)
		elseif ConfiguringShape == "Stair" or ConfiguringShape == "StairInnerCorner" or ConfiguringShape == "StairOuterCorner" then
			blockPreview.Size = UDim2.new(0, 40, 0, 30)
		else
			blockPreview.Size = UDim2.new(0, 40, 0, 40)
		end
	end
end

local function selectShape(shapeId)
	ConfiguringShape = shapeId
	ConfiguringMaterial = Enum.Material.Plastic
	ConfiguringColor = Color3.fromRGB(163, 162, 165)
	
	if CustomizerPanel then
		CustomizerPanel.Visible = true
		updateCustomizerPreview()
		
		local label = CustomizerPanel:FindFirstChild("Label")
		local shape = BlockShapes.GetShape(shapeId)
		if label and shape then
			label.Text = "Customize: " .. shape.Name
		end
	end
end

local function selectColor(color)
	ConfiguringColor = color
	updateCustomizerPreview()
end

local function selectMaterial(material)
	ConfiguringMaterial = material
	updateCustomizerPreview()
end

local function addToHotbar(slotNumber)
	if not ConfiguringShape then return end
	
	Hotbar[slotNumber] = {
		ShapeId = ConfiguringShape,
		Material = ConfiguringMaterial,
		Color = ConfiguringColor,
	}
	
	updateHotbarSlot(slotNumber)
	
	local slot = SlotFrames[slotNumber]
	if slot then
		local originalColor = slot.BackgroundColor3
		slot.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
		task.delay(0.2, function()
			TweenService:Create(slot, TweenInfo.new(0.3), {BackgroundColor3 = originalColor}):Play()
		end)
	end
end

local function openInventory()
	if InventoryPanel then
		InventoryPanel.Visible = true
		InventoryOpen = true
		ConfiguringShape = nil
		if CustomizerPanel then
			CustomizerPanel.Visible = false
		end
	end
end

local function closeInventory()
	if InventoryPanel then
		InventoryPanel.Visible = false
		InventoryOpen = false
	end
end

local function toggleInventory()
	if InventoryOpen then
		closeInventory()
	else
		openInventory()
	end
end

local function getSelectedBlock()
	local data = Hotbar[CurrentSlot]
	if not data then return nil end
	
	local shape = BlockShapes.GetShape(data.ShapeId)
	if not shape then return nil end
	
	return {
		Id = data.ShapeId,
		Name = shape.Name,
		TemplateName = shape.TemplateName,
		Offset = shape.Offset,
		CanRotate = shape.CanRotate,
		Material = data.Material,
		Color = data.Color,
	}
end

local function rotateBlock()
	local data = Hotbar[CurrentSlot]
	if not data then return end
	
	local shape = BlockShapes.GetShape(data.ShapeId)
	if shape and shape.CanRotate then
		CurrentRotation = (CurrentRotation + 90) % 360
		print("Rotation: " .. CurrentRotation)
	end
end

--====================--
--    HOTBAR UI       --
--====================--

local function createHotbarSlot(slotNumber)
	local slot = Instance.new("TextButton")
	slot.Name = "Slot" .. slotNumber
	slot.Size = UDim2.new(0, 46, 0, 46)
	slot.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	slot.BorderSizePixel = 0
	slot.Text = ""
	slot.AutoButtonColor = false
	
	local slotCorner = Instance.new("UICorner")
	slotCorner.CornerRadius = UDim.new(0, 6)
	slotCorner.Parent = slot
	
	local numLabel = Instance.new("TextLabel")
	numLabel.Name = "Number"
	numLabel.Position = UDim2.new(0, 3, 0, 2)
	numLabel.Size = UDim2.new(0, 14, 0, 14)
	numLabel.BackgroundTransparency = 1
	numLabel.Text = tostring(slotNumber)
	numLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
	numLabel.TextSize = 11
	numLabel.Font = Enum.Font.GothamBold
	numLabel.Parent = slot
	
	local preview = Instance.new("Frame")
	preview.Name = "Preview"
	preview.AnchorPoint = Vector2.new(0.5, 0.5)
	preview.Position = UDim2.new(0.5, 0, 0.55, 0)
	preview.Size = UDim2.new(0, 28, 0, 28)
	preview.BackgroundTransparency = 1
	preview.BorderSizePixel = 0
	preview.Parent = slot
	
	local previewCorner = Instance.new("UICorner")
	previewCorner.CornerRadius = UDim.new(0, 4)
	previewCorner.Parent = preview
	
	slot.MouseButton1Click:Connect(function()
		selectSlot(slotNumber)
	end)
	
	return slot
end

local function createHotbarUI()
	ScreenGui = Instance.new("ScreenGui")
	ScreenGui.Name = "InventoryGui"
	ScreenGui.ResetOnSpawn = false
	ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	ScreenGui.Parent = PlayerGui
	
	HotbarFrame = Instance.new("Frame")
	HotbarFrame.Name = "Hotbar"
	HotbarFrame.AnchorPoint = Vector2.new(0.5, 1)
	HotbarFrame.Position = UDim2.new(0.5, 0, 1, -20)
	HotbarFrame.Size = UDim2.new(0, 470, 0, 60)
	HotbarFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	HotbarFrame.BackgroundTransparency = 0.3
	HotbarFrame.BorderSizePixel = 0
	HotbarFrame.Parent = ScreenGui
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = HotbarFrame
	
	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.VerticalAlignment = Enum.VerticalAlignment.Center
	layout.Padding = UDim.new(0, 6)
	layout.Parent = HotbarFrame
	
	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, 8)
	padding.PaddingRight = UDim.new(0, 8)
	padding.Parent = HotbarFrame
	
	for i = 1, 9 do
		local slot = createHotbarSlot(i)
		slot.Parent = HotbarFrame
		SlotFrames[i] = slot
	end
	
	SelectionFrame = Instance.new("Frame")
	SelectionFrame.Name = "Selection"
	SelectionFrame.Size = UDim2.new(0, 52, 0, 52)
	SelectionFrame.Position = UDim2.new(0, 5, 0.5, -26)
	SelectionFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	SelectionFrame.BackgroundTransparency = 0.7
	SelectionFrame.BorderSizePixel = 0
	SelectionFrame.ZIndex = 0
	SelectionFrame.Parent = HotbarFrame
	
	local selCorner = Instance.new("UICorner")
	selCorner.CornerRadius = UDim.new(0, 8)
	selCorner.Parent = SelectionFrame
	
	BlockNameLabel = Instance.new("TextLabel")
	BlockNameLabel.Name = "BlockName"
	BlockNameLabel.AnchorPoint = Vector2.new(0.5, 1)
	BlockNameLabel.Position = UDim2.new(0.5, 0, 0, -5)
	BlockNameLabel.Size = UDim2.new(0, 200, 0, 20)
	BlockNameLabel.BackgroundTransparency = 1
	BlockNameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	BlockNameLabel.TextSize = 14
	BlockNameLabel.Font = Enum.Font.GothamBold
	BlockNameLabel.TextStrokeTransparency = 0.5
	BlockNameLabel.Text = "Empty"
	BlockNameLabel.Parent = HotbarFrame
	
	local hintLabel = Instance.new("TextLabel")
	hintLabel.Name = "Hint"
	hintLabel.AnchorPoint = Vector2.new(0.5, 0)
	hintLabel.Position = UDim2.new(0.5, 0, 1, 5)
	hintLabel.Size = UDim2.new(0, 200, 0, 16)
	hintLabel.BackgroundTransparency = 1
	hintLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
	hintLabel.TextSize = 12
	hintLabel.Font = Enum.Font.Gotham
	hintLabel.TextStrokeTransparency = 0.7
	hintLabel.Text = "Press E to open inventory"
	hintLabel.Parent = HotbarFrame
	
	updateSelection()
end

--====================--
--   INVENTORY UI     --
--====================--

local function createShapesPanel()
	local shapesPanel = Instance.new("Frame")
	shapesPanel.Name = "ShapesPanel"
	shapesPanel.Position = UDim2.new(0, 20, 0, 60)
	shapesPanel.Size = UDim2.new(1, -40, 0, 120)
	shapesPanel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	shapesPanel.BorderSizePixel = 0
	shapesPanel.Parent = InventoryPanel
	
	local panelCorner = Instance.new("UICorner")
	panelCorner.CornerRadius = UDim.new(0, 8)
	panelCorner.Parent = shapesPanel
	
	local label = Instance.new("TextLabel")
	label.Name = "Label"
	label.Position = UDim2.new(0, 10, 0, 8)
	label.Size = UDim2.new(1, -20, 0, 20)
	label.BackgroundTransparency = 1
	label.Text = "Select Shape"
	label.TextColor3 = Color3.fromRGB(200, 200, 200)
	label.TextSize = 14
	label.Font = Enum.Font.GothamBold
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = shapesPanel
	
	local container = Instance.new("Frame")
	container.Name = "Shapes"
	container.Position = UDim2.new(0, 10, 0, 35)
	container.Size = UDim2.new(1, -20, 1, -45)
	container.BackgroundTransparency = 1
	container.Parent = shapesPanel
	
	local gridLayout = Instance.new("UIGridLayout")
	gridLayout.CellSize = UDim2.new(0, 70, 0, 70)
	gridLayout.CellPadding = UDim2.new(0, 8, 0, 8)
	gridLayout.Parent = container
	
	for _, shape in ipairs(BlockShapes.GetAllShapes()) do
		local btn = Instance.new("TextButton")
		btn.Name = shape.Id
		btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
		btn.BorderSizePixel = 0
		btn.Text = ""
		btn.AutoButtonColor = false
		btn.Parent = container
		
		local btnCorner = Instance.new("UICorner")
		btnCorner.CornerRadius = UDim.new(0, 6)
		btnCorner.Parent = btn
		
		local preview = Instance.new("Frame")
		preview.Name = "Preview"
		preview.AnchorPoint = Vector2.new(0.5, 0.5)
		preview.Position = UDim2.new(0.5, 0, 0.4, 0)
		preview.BackgroundColor3 = Color3.fromRGB(163, 162, 165)
		preview.BorderSizePixel = 0
		preview.Parent = btn
		
		local previewCorner = Instance.new("UICorner")
		previewCorner.CornerRadius = UDim.new(0, 4)
		previewCorner.Parent = preview
		
		if shape.Id == "Slab" then
			preview.Size = UDim2.new(0, 32, 0, 16)
		elseif shape.Id == "Stair" or shape.Id == "StairInnerCorner" or shape.Id == "StairOuterCorner" then
			preview.Size = UDim2.new(0, 32, 0, 24)
		else
			preview.Size = UDim2.new(0, 32, 0, 32)
		end
		
		local nameLabel = Instance.new("TextLabel")
		nameLabel.Name = "Name"
		nameLabel.Position = UDim2.new(0, 2, 1, -16)
		nameLabel.Size = UDim2.new(1, -4, 0, 14)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = shape.Name
		nameLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
		nameLabel.TextSize = 9
		nameLabel.Font = Enum.Font.Gotham
		nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
		nameLabel.Parent = btn
		
		btn.MouseButton1Click:Connect(function()
			selectShape(shape.Id)
		end)
		
		btn.MouseEnter:Connect(function()
			TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(80, 80, 80)}):Play()
		end)
		
		btn.MouseLeave:Connect(function()
			TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(60, 60, 60)}):Play()
		end)
	end
end

