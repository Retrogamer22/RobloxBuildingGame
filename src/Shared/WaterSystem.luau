--[[
	WaterSystem
	Minecraft-style water flow simulation for BuildBlox.
	
	Water levels:
		0 = Source block (full height, permanent until removed by bucket)
		1-7 = Flowing water (decreasing height, generated by propagation)
	
	Flow rules (matching Minecraft):
		- Source blocks spread horizontally up to 7 blocks (taxicab distance)
		- Each flowing block has level = parent level + 1, visually shorter
		- Water falls straight down through air (resets to level 1 at bottom)
		- When spreading horizontally, water PREFERS directions with a nearby
		  drop (within 4 blocks) — Minecraft's "edge-seeking" pathfinding
		- Infinite source: empty space with 2+ adjacent source blocks on solid
		  ground becomes a new source
		- Each position keeps the LOWEST level (strongest flow) from any source
	
	Terrain awareness:
		- Uses TerrainLogic to determine actual surface height at any position
		- Positions at or below the terrain surface with no spawned block are
		  treated as solid (lazy loading hasn't revealed them yet)
		- Positions ABOVE the terrain surface with no block are air (water flows)
	
	Grid: BLOCK_SIZE = 3 studs per block
	Water height per level: 3 * (8 - level) / 8 studs
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local TerrainLogic = require(ReplicatedStorage:WaitForChild("TerrainLogic", 10))

local WaterSystem = {}

-- ============================================
-- CONSTANTS
-- ============================================

local BLOCK_SIZE = 3
local MAX_FLOW_DISTANCE = 7  -- Max horizontal spread from source (levels 1-7)
local SOURCE_LEVEL = 0
local MAX_LEVEL = 7
local EDGE_SEARCH_DEPTH = 4  -- Minecraft checks 4 blocks for nearby drops

-- Horizontal neighbor offsets (N, S, E, W)
local HORIZONTAL_OFFSETS = {
	Vector3.new(BLOCK_SIZE, 0, 0),   -- +X (East)
	Vector3.new(-BLOCK_SIZE, 0, 0),  -- -X (West)
	Vector3.new(0, 0, BLOCK_SIZE),   -- +Z (South)
	Vector3.new(0, 0, -BLOCK_SIZE),  -- -Z (North)
}

local DOWN_OFFSET = Vector3.new(0, -BLOCK_SIZE, 0)
local UP_OFFSET = Vector3.new(0, BLOCK_SIZE, 0)

-- ============================================
-- UTILITY
-- ============================================

-- Generate a grid key from a position
local function posKey(pos)
	local gx = math.round(pos.X / BLOCK_SIZE)
	local gy = math.round(pos.Y / BLOCK_SIZE)
	local gz = math.round(pos.Z / BLOCK_SIZE)
	return gx .. "," .. gy .. "," .. gz
end

-- Snap a position to grid center
-- If buildArea is provided, snaps to the TERRAIN grid (which may be offset
-- from the absolute world grid). Without buildArea, snaps to absolute grid.
function WaterSystem.SnapToGrid(pos, buildArea)
	if buildArea then
		local startX = buildArea:GetAttribute("TerrainStartX")
		local startZ = buildArea:GetAttribute("TerrainStartZ")
		local surfaceY = buildArea:GetAttribute("TerrainSurfaceY")
		
		if startX and startZ then
			-- Snap X,Z to terrain grid
			local gx = math.round((pos.X - startX) / BLOCK_SIZE) * BLOCK_SIZE + startX
			local gz = math.round((pos.Z - startZ) / BLOCK_SIZE) * BLOCK_SIZE + startZ
			-- Snap Y relative to terrain surface so water layers align
			local originY = surfaceY or 0
			local gy = math.round((pos.Y - originY) / BLOCK_SIZE) * BLOCK_SIZE + originY
			return Vector3.new(gx, gy, gz)
		end
	end
	
	-- Fallback: absolute grid
	return Vector3.new(
		math.round(pos.X / BLOCK_SIZE) * BLOCK_SIZE,
		math.round(pos.Y / BLOCK_SIZE) * BLOCK_SIZE,
		math.round(pos.Z / BLOCK_SIZE) * BLOCK_SIZE
	)
end

-- Get the visual height of water at a given level
function WaterSystem.GetWaterHeight(level)
	if level == SOURCE_LEVEL then
		return BLOCK_SIZE -- Full block
	end
	return BLOCK_SIZE * (8 - level) / 8
end

-- Check if a block type is water
function WaterSystem.IsWater(blockType)
	return blockType == "Water" or blockType == "WaterSource" or blockType == "WaterFlowing"
end

-- ============================================
-- TERRAIN-AWARE SOLIDITY CHECKS
-- ============================================

--[[
	Determines if a grid position should be treated as "solid" for water flow.
	
	A position is solid if:
	1. There's an actual non-water, non-decoration block there, OR
	2. The position is at or below the terrain surface AND no block exists there
	   AND the player hasn't dug it out (lazy loading territory)
	
	The key insight: with lazy loading, underground blocks don't exist until the
	player digs adjacent blocks. So we use TerrainLogic to ask "should there be
	terrain here?" If yes and nothing is spawned, it's solid ground.
]]

-- Check if a position has an actual solid block placed there
local function hasRealSolidBlock(pos, spatialIndex)
	if not spatialIndex then return false end
	local blocks = spatialIndex:GetBlocksAt(pos)
	for _, block in ipairs(blocks) do
		local blockType = block:GetAttribute("BlockType")
		if blockType and not WaterSystem.IsWater(blockType) and not block:GetAttribute("IsDecoration") then
			return true
		end
	end
	return false
end

-- Check if a position has any block at all (solid, water, or decoration)
local function hasAnyBlock(pos, spatialIndex)
	if not spatialIndex then return false end
	local blocks = spatialIndex:GetBlocksAt(pos)
	for _, block in ipairs(blocks) do
		local blockType = block:GetAttribute("BlockType")
		if blockType and not block:GetAttribute("IsDecoration") then
			return true
		end
	end
	return false
end

-- Check if a position has water (returns the water block and its level, or nil)
-- MUST be defined before isSolid since isSolid references it
local function getWaterAt(pos, spatialIndex)
	if not spatialIndex then return nil, nil end
	local blocks = spatialIndex:GetBlocksAt(pos)
	for _, block in ipairs(blocks) do
		local blockType = block:GetAttribute("BlockType")
		if blockType and WaterSystem.IsWater(blockType) then
			local level = block:GetAttribute("WaterLevel") or 0
			return block, level
		end
	end
	return nil, nil
end

-- ============================================
-- BOUNDS CHECKS
-- ============================================

-- Check if position is within plot bounds
local function isInPlotBounds(pos, buildArea)
	local posX = buildArea:GetAttribute("BasePlatePositionX")
	local posY = buildArea:GetAttribute("BasePlatePositionY")
	local posZ = buildArea:GetAttribute("BasePlatePositionZ")
	local sizeX = buildArea:GetAttribute("BasePlateSizeX")
	local sizeY = buildArea:GetAttribute("BasePlateSizeY")
	local sizeZ = buildArea:GetAttribute("BasePlateSizeZ")
	
	if not (posX and posY and posZ and sizeX and sizeY and sizeZ) then
		return false
	end
	
	local halfX = sizeX / 2
	local halfZ = sizeZ / 2
	
	if pos.X < posX - halfX or pos.X > posX + halfX then return false end
	if pos.Z < posZ - halfZ or pos.Z > posZ + halfZ then return false end
	
	local plateTop = posY + sizeY / 2
	local minY = plateTop - 40 * BLOCK_SIZE - BLOCK_SIZE
	local maxY = plateTop + 400
	if pos.Y < minY or pos.Y > maxY then return false end
	
	return true
end

-- Extended bounds for water flow: allows water to spill 1 block past the
-- plot edge horizontally so it can cascade down like a waterfall.
-- Vertically capped to a short distance below the surface.
local WATER_EDGE_EXTENSION = BLOCK_SIZE -- 1 block past plot edge
local WATER_FALL_DEPTH = 10 * BLOCK_SIZE -- Max waterfall height

local function isInWaterBounds(pos, buildArea)
	local posX = buildArea:GetAttribute("BasePlatePositionX")
	local posY = buildArea:GetAttribute("BasePlatePositionY")
	local posZ = buildArea:GetAttribute("BasePlatePositionZ")
	local sizeX = buildArea:GetAttribute("BasePlateSizeX")
	local sizeY = buildArea:GetAttribute("BasePlateSizeY")
	local sizeZ = buildArea:GetAttribute("BasePlateSizeZ")
	
	if not (posX and posY and posZ and sizeX and sizeY and sizeZ) then
		return false
	end
	
	local halfX = sizeX / 2 + WATER_EDGE_EXTENSION
	local halfZ = sizeZ / 2 + WATER_EDGE_EXTENSION
	
	if pos.X < posX - halfX or pos.X > posX + halfX then return false end
	if pos.Z < posZ - halfZ or pos.Z > posZ + halfZ then return false end
	
	local plateTop = posY + sizeY / 2
	local surfaceY = buildArea:GetAttribute("TerrainSurfaceY") or plateTop
	local minY = surfaceY - WATER_FALL_DEPTH
	local maxY = plateTop + 400
	if pos.Y < minY or pos.Y > maxY then return false end
	
	return true
end

-- ============================================
-- TERRAIN SOLIDITY
-- ============================================

local SOLID_EPSILON = 0.1 -- Tolerance for floating point grid comparisons

local function isSolid(pos, spatialIndex, buildArea)
	-- 1. Real solid block in spatial index? Always solid.
	if hasRealSolidBlock(pos, spatialIndex) then
		return true
	end
	
	-- 2. No real block at this position. Check terrain to decide if it's
	--    unloaded underground (solid) or genuinely empty (air).
	--    ONLY apply terrain logic inside the actual plot bounds.
	--    Outside the plot there is no terrain — just air.
	if buildArea and isInPlotBounds(pos, buildArea) then
		local surfaceY = TerrainLogic.GetSurfaceYAtPosition(pos, buildArea)
		if surfaceY then
			local terrainTop = surfaceY + BLOCK_SIZE
			
			-- Above terrain ceiling: definitely air
			-- Use epsilon to handle floating point: pos at terrainTop is air
			if pos.Y >= terrainTop - SOLID_EPSILON then
				return false
			end
			
			-- At or below terrain: could be unloaded underground OR a
			-- player-dug hole. Check whether the surface (grass) block at
			-- this X,Z column still exists.
			local surfaceBlockPos = Vector3.new(pos.X, surfaceY, pos.Z)
			if hasRealSolidBlock(surfaceBlockPos, spatialIndex) then
				-- Surface intact → everything underground is unloaded → solid
				return true
			end
			
			-- Surface block is gone at this X,Z. The player has dug here,
			-- so lazy loading has kicked in and the spatial index is the
			-- source of truth. No real block at our position = air.
			return false
		end
	end
	
	-- 3. Outside plot or no terrain info = air (no block found)
	return false
end

-- ============================================
-- EDGE-SEEKING PATHFINDING (Minecraft-style)
-- ============================================

--[[
	Minecraft's water doesn't spread equally in all directions. Before flowing,
	it checks each of the 4 horizontal directions to see if there's a drop
	(air below a reachable position) within EDGE_SEARCH_DEPTH blocks. If a
	drop is found, water ONLY flows toward the direction(s) with the shortest
	path to a drop. If no drops are found, water spreads equally in all
	available directions.
	
	This makes water "seek" edges and holes, looking much more natural than
	uniform diamond spreading.
]]

-- Find the shortest distance to a drop in a given direction using BFS
-- Returns the distance (1 to EDGE_SEARCH_DEPTH) or nil if no drop found
local function findDropDistance(startPos, direction, spatialIndex, buildArea, flowMap)
	-- BFS outward in the given direction, also branching to other horizontal dirs
	-- We're looking for any reachable position (within EDGE_SEARCH_DEPTH taxicab
	-- distance from startPos+direction) that has air below it
	
	local searchQueue = {}
	local visited = {}
	
	-- Start one step in the given direction
	local firstStep = startPos + direction
	local firstKey = posKey(firstStep)
	
	-- The first step must be passable (not solid, in bounds)
	if not isInWaterBounds(firstStep, buildArea) then return nil end
	if isSolid(firstStep, spatialIndex, buildArea) then return nil end
	
	table.insert(searchQueue, { pos = firstStep, dist = 1 })
	visited[firstKey] = true
	
	local head = 1
	while head <= #searchQueue do
		local current = searchQueue[head]
		head += 1
		
		local pos = current.pos
		local dist = current.dist
		
		-- Check if there's a drop here (air below)
		local belowPos = pos + DOWN_OFFSET
		if not isSolid(belowPos, spatialIndex, buildArea) then
			-- Check it's not already water flowing down (only count empty air as a drop)
			local belowKey = posKey(belowPos)
			local belowInFlow = flowMap and flowMap[belowKey]
			-- Even if there's water below, a drop is still a drop (water falls further)
			return dist
		end
		
		-- If we haven't reached max search depth, continue searching
		if dist < EDGE_SEARCH_DEPTH then
			for _, offset in ipairs(HORIZONTAL_OFFSETS) do
				local nextPos = pos + offset
				local nextKey = posKey(nextPos)
				
				if not visited[nextKey] then
					visited[nextKey] = true
					
					if isInWaterBounds(nextPos, buildArea) and not isSolid(nextPos, spatialIndex, buildArea) then
						table.insert(searchQueue, { pos = nextPos, dist = dist + 1 })
					end
				end
			end
		end
	end
	
	return nil -- No drop found within search depth
end

-- Get the preferred flow directions from a position
-- Returns a table of direction vectors the water should flow toward
local function getPreferredDirections(pos, spatialIndex, buildArea, flowMap)
	local directionWeights = {} -- { direction = Vector3, weight = number }
	local minWeight = math.huge
	local hasAnyDrop = false
	
	for _, offset in ipairs(HORIZONTAL_OFFSETS) do
		local neighborPos = pos + offset
		
		-- Skip if not passable
		if not isInWaterBounds(neighborPos, buildArea) then continue end
		if isSolid(neighborPos, spatialIndex, buildArea) then continue end
		
		-- Search for a drop in this direction
		local dropDist = findDropDistance(pos, offset, spatialIndex, buildArea, flowMap)
		
		if dropDist then
			hasAnyDrop = true
			table.insert(directionWeights, { direction = offset, weight = dropDist })
			if dropDist < minWeight then
				minWeight = dropDist
			end
		else
			-- No drop found - assign high weight (1000, like Minecraft)
			table.insert(directionWeights, { direction = offset, weight = 1000 })
		end
	end
	
	-- If any drops were found, only return directions with the minimum weight
	-- If no drops found, return all passable directions (uniform spread)
	local preferred = {}
	for _, entry in ipairs(directionWeights) do
		if not hasAnyDrop or entry.weight == minWeight then
			table.insert(preferred, entry.direction)
		end
	end
	
	return preferred
end

-- ============================================
-- FLOW CALCULATION (BFS with edge-seeking)
-- ============================================

--[[
	CalculateFlow:
	Given all source blocks in a region, calculates the desired water state
	for every position that should have water.
	
	Returns: { [posKey] = { position = Vector3, level = number, isFalling = bool } }
	
	Algorithm:
	1. Collect all source blocks (level 0)
	2. Check infinite source rule (create new sources where applicable)
	3. BFS from each source:
	   a. Check below: if air, flow downward (falling water, level resets)
	   b. If on solid ground, use edge-seeking to pick preferred directions
	   c. Spread horizontally in preferred directions (level +1 per step)
	4. Each position keeps the minimum level from any contributing source
]]
function WaterSystem.CalculateFlow(blocksFolder, buildArea, spatialIndex)
	local flowMap = {} -- posKey -> { position, level, isFalling, distance }
	local queue = {}   -- BFS queue: { position, level, isFalling, distance }
	
	-- Step 1: Find all existing source blocks
	for _, block in ipairs(blocksFolder:GetChildren()) do
		if block:GetAttribute("WaterLevel") == SOURCE_LEVEL and WaterSystem.IsWater(block:GetAttribute("BlockType")) then
			local bx = block:GetAttribute("BlockPosX")
			local by = block:GetAttribute("BlockPosY")
			local bz = block:GetAttribute("BlockPosZ")
			local pos
			if bx and by and bz then
				pos = Vector3.new(bx, by, bz)
			elseif block:IsA("BasePart") then
				pos = WaterSystem.SnapToGrid(block.Position)
			end
			
			if pos then
				local key = posKey(pos)
				flowMap[key] = { position = pos, level = SOURCE_LEVEL, isFalling = false, distance = 0 }
				table.insert(queue, { position = pos, level = SOURCE_LEVEL, isFalling = false, distance = 0 })
			end
		end
	end
	
	-- Step 2: Infinite source rule
	-- A position with 2+ adjacent source blocks on solid ground becomes a source
	local newSourcesCreated = true
	while newSourcesCreated do
		newSourcesCreated = false
		
		-- Collect current source positions
		local sourcePositions = {}
		for key, data in pairs(flowMap) do
			if data.level == SOURCE_LEVEL then
				table.insert(sourcePositions, data.position)
			end
		end
		
		-- For each source, check horizontal neighbors for candidate positions
		local candidates = {} -- posKey -> { position, count }
		for _, srcPos in ipairs(sourcePositions) do
			for _, offset in ipairs(HORIZONTAL_OFFSETS) do
				local checkPos = srcPos + offset
				local checkKey = posKey(checkPos)
				
				-- Must not already be a source and must not be solid
				if (not flowMap[checkKey] or flowMap[checkKey].level ~= SOURCE_LEVEL) 
					and not isSolid(checkPos, spatialIndex, buildArea) then
					if not candidates[checkKey] then
						candidates[checkKey] = { position = checkPos, count = 0 }
					end
					candidates[checkKey].count += 1
				end
			end
		end
		
		-- Create new sources where 2+ adjacent sources exist on solid support
		for key, candidate in pairs(candidates) do
			if candidate.count >= 2 then
				-- Must have solid support below (or water below)
				local belowPos = candidate.position + DOWN_OFFSET
				local hasSupportBelow = isSolid(belowPos, spatialIndex, buildArea)
				if not hasSupportBelow then
					-- Water below counts as support
					local belowKey = posKey(belowPos)
					if flowMap[belowKey] then
						hasSupportBelow = true
					else
						local waterBelow, _ = getWaterAt(belowPos, spatialIndex)
						if waterBelow then
							hasSupportBelow = true
						end
					end
				end
				
				if hasSupportBelow and (not flowMap[key] or flowMap[key].level > SOURCE_LEVEL) then
					flowMap[key] = { position = candidate.position, level = SOURCE_LEVEL, isFalling = false, distance = 0 }
					table.insert(queue, { position = candidate.position, level = SOURCE_LEVEL, isFalling = false, distance = 0 })
					newSourcesCreated = true
				end
			end
		end
	end
	
	-- Step 3: BFS propagation with edge-seeking
	local head = 1
	local processedCount = 0
	local MAX_ITERATIONS = 50000
	
	while head <= #queue and processedCount < MAX_ITERATIONS do
		local current = queue[head]
		head += 1
		processedCount += 1
		
		local pos = current.position
		local level = current.level
		local falling = current.isFalling
		local dist = current.distance or 0
		
		-- Skip if this entry was superseded by a stronger flow
		local key = posKey(pos)
		local currentBest = flowMap[key]
		if currentBest and currentBest.level < level then
			continue -- A stronger path already reached here
		end
		
		-- Check bounds
		if not isInWaterBounds(pos, buildArea) then continue end
		
		-- === DOWNWARD FLOW (gravity - always check first) ===
		local belowPos = pos + DOWN_OFFSET
		local belowKey = posKey(belowPos)
		local canFlowDown = false
		
		if isInWaterBounds(belowPos, buildArea) and not isSolid(belowPos, spatialIndex, buildArea) then
			canFlowDown = true
			
			-- Falling water renders full-width but is marked as falling
			-- Level stays at 1 for flowing-source falls (not a real source)
			local fallingLevel = 1
			if level == SOURCE_LEVEL then
				fallingLevel = 1 -- Even source blocks produce level-1 falling water below
			end
			
			local nextDist = dist + 1
			local existingBelow = flowMap[belowKey]
			if not existingBelow or existingBelow.level > fallingLevel then
				flowMap[belowKey] = { position = belowPos, level = fallingLevel, isFalling = true, distance = nextDist }
				table.insert(queue, { position = belowPos, level = fallingLevel, isFalling = true, distance = nextDist })
			end
		end
		
		-- === HORIZONTAL FLOW ===
		-- In Minecraft: flowing water with air below does NOT spread sideways
		-- (it falls instead). Only source blocks and water on solid ground spread.
		
		-- Check if we should spread horizontally
		local shouldSpreadHorizontally = false
		
		if level == SOURCE_LEVEL then
			-- Source blocks ALWAYS spread horizontally (even with air below)
			shouldSpreadHorizontally = true
		elseif not canFlowDown then
			-- Water on solid ground spreads horizontally
			shouldSpreadHorizontally = true
		else
			-- Flowing water with air below: just fall, don't spread
			shouldSpreadHorizontally = false
		end
		
		if shouldSpreadHorizontally then
			-- Calculate next level for neighbors
			local nextLevel
			if falling and level ~= SOURCE_LEVEL then
				-- After falling, horizontal spread restarts from level 1
				nextLevel = 1
			else
				nextLevel = level + 1
			end
			
			-- Source blocks get level 1 neighbors (not level 0+1=1... wait, that's the same)
			-- Actually: source=0, so nextLevel = 0+1 = 1, which is correct
			
			if nextLevel <= MAX_LEVEL then
				local nextDist = dist + 1
				
				-- Use edge-seeking pathfinding to determine preferred directions
				-- (Only for source blocks and level-1 to reduce computation cost;
				--  higher levels just spread uniformly since they're already flowing)
				local directions
				if level <= 1 then
					directions = getPreferredDirections(pos, spatialIndex, buildArea, flowMap)
				else
					-- For levels 2+, spread in all passable directions (cheaper)
					directions = {}
					for _, offset in ipairs(HORIZONTAL_OFFSETS) do
						local neighborPos = pos + offset
						if isInWaterBounds(neighborPos, buildArea) and not isSolid(neighborPos, spatialIndex, buildArea) then
							table.insert(directions, offset)
						end
					end
				end
				
				for _, offset in ipairs(directions) do
					local neighborPos = pos + offset
					local neighborKey = posKey(neighborPos)
					
					-- Only update if this path provides a lower (stronger) level
					local existing = flowMap[neighborKey]
					if not existing or existing.level > nextLevel then
						flowMap[neighborKey] = { position = neighborPos, level = nextLevel, isFalling = false, distance = nextDist }
						table.insert(queue, { position = neighborPos, level = nextLevel, isFalling = false, distance = nextDist })
					end
				end
			end
		end
	end
	
	if processedCount >= MAX_ITERATIONS then
		warn("[WaterSystem] Hit max iteration limit during flow calculation!")
	end
	
	-- Debug summary
	local totalBlocks = 0
	local fallingCount = 0
	local maxDist = 0
	local levelCounts = {}
	for _, data in pairs(flowMap) do
		totalBlocks += 1
		if data.isFalling then fallingCount += 1 end
		if (data.distance or 0) > maxDist then maxDist = data.distance or 0 end
		local l = data.level
		levelCounts[l] = (levelCounts[l] or 0) + 1
	end
	local levelStr = ""
	for l = 0, MAX_LEVEL do
		if levelCounts[l] then
			levelStr = levelStr .. string.format(" L%d=%d", l, levelCounts[l])
		end
	end
	print(string.format("[WaterSystem] Flow: total=%d falling=%d maxDist=%d%s",
		totalBlocks, fallingCount, maxDist, levelStr))
	
	return flowMap
end

-- ============================================
-- FLOW DIRECTION (for visual effects and player push)
-- ============================================

-- Calculate the flow direction at a given position based on neighboring water levels
function WaterSystem.GetFlowDirection(pos, flowMap)
	local key = posKey(pos)
	local current = flowMap[key]
	if not current then return Vector3.zero end
	
	if current.isFalling then
		return Vector3.new(0, -1, 0)
	end
	
	-- Water flows from lower level numbers (closer to source) toward higher ones
	local flowDir = Vector3.zero
	
	for _, offset in ipairs(HORIZONTAL_OFFSETS) do
		local neighborPos = pos + offset
		local neighborKey = posKey(neighborPos)
		local neighbor = flowMap[neighborKey]
		
		-- Treat air/edges as MAX_LEVEL + 1 (water flows toward them)
		local neighborLevel = neighbor and neighbor.level or (MAX_LEVEL + 1)
		
		if neighborLevel > current.level then
			flowDir = flowDir + offset.Unit
		elseif neighborLevel < current.level then
			flowDir = flowDir - offset.Unit
		end
	end
	
	if flowDir.Magnitude > 0 then
		return flowDir.Unit
	end
	return Vector3.zero
end

-- ============================================
-- WATER BLOCK VISUAL PROPERTIES
-- ============================================

function WaterSystem.GetWaterVisualProperties(level, isFalling)
	local height
	if isFalling then
		height = BLOCK_SIZE -- Falling water is full height visually
	else
		height = WaterSystem.GetWaterHeight(level)
	end
	
	-- Size: full width, variable height
	local size = Vector3.new(BLOCK_SIZE, height, BLOCK_SIZE)
	
	-- Position offset: bottom-aligned in grid cell
	local yOffset = -BLOCK_SIZE / 2 + height / 2
	
	return {
		Size = size,
		YOffset = yOffset,
		Height = height,
		Color = Color3.fromRGB(30, 100, 200),
		Transparency = 0.35,
		Material = Enum.Material.Glass,
	}
end

-- ============================================
-- CONSTANTS EXPOSED
-- ============================================

WaterSystem.BLOCK_SIZE = BLOCK_SIZE
WaterSystem.MAX_FLOW_DISTANCE = MAX_FLOW_DISTANCE
WaterSystem.SOURCE_LEVEL = SOURCE_LEVEL
WaterSystem.MAX_LEVEL = MAX_LEVEL
WaterSystem.HORIZONTAL_OFFSETS = HORIZONTAL_OFFSETS
WaterSystem.DOWN_OFFSET = DOWN_OFFSET
WaterSystem.UP_OFFSET = UP_OFFSET
WaterSystem.PosKey = posKey

return WaterSystem
