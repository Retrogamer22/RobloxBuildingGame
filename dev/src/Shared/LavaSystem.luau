--[[
	LavaSystem
	Minecraft-style lava flow simulation for BuildBlox.
	Architecturally identical to WaterSystem but with lava-specific tuning:
	
		- Shorter spread distance (MAX_FLOW_DISTANCE = 4, like Nether lava)
		- No infinite-source rule (lava doesn't make new sources)
		- No water/lava interaction yet (decided later)
		- Bright opaque visual instead of transparent blue
		
	Wave delay (how slowly flow visually propagates) is configured in
	LavaHandler.server.luau, NOT here — same as how WaterHandler owns
	the WAVE_DELAY constant. This module is pure logic.

	Lava levels:
		0 = Source block (full height, permanent until removed by bucket)
		1-MAX_LEVEL = Flowing lava (decreasing height, generated by propagation)
	
	Flow rules:
		- Source blocks spread horizontally up to MAX_FLOW_DISTANCE
		- Each flowing block has level = parent level + 1, visually shorter
		- Lava falls straight down through air (resets to level 1 at bottom)
		- Edge-seeking pathfinding identical to water
		- Each position keeps the LOWEST level (strongest flow) from any source
	
	Grid: BLOCK_SIZE = 3 studs per block
	Lava height per level: 3 * (MAX_LEVEL + 1 - level) / (MAX_LEVEL + 1) studs
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local TerrainLogic = require(ReplicatedStorage:WaitForChild("TerrainLogic", 10))

local LavaSystem = {}

-- TerrainGenerator integration: set by LavaHandler at server-init so isSolid
-- can ask "has this terrain cell been dug?". Without this, dug terrain still
-- reads as solid (via TerrainLogic.GetSurfaceYAtPosition) and lava won't
-- flow into excavations. Optional — if not set, falls back to the surface-Y
-- check alone (correct for un-dug terrain).
LavaSystem._TerrainGenerator = nil
LavaSystem._PlotNumberLookup = nil  -- function(buildArea) -> plotNumber, or nil
LavaSystem._DebugFlow = false       -- set true to log isSolid/dug-check decisions
function LavaSystem.SetTerrainHooks(terrainGenerator, plotNumberLookup)
	LavaSystem._TerrainGenerator = terrainGenerator
	LavaSystem._PlotNumberLookup = plotNumberLookup
end
function LavaSystem.SetDebugFlow(enabled)
	LavaSystem._DebugFlow = enabled and true or false
end

-- ============================================
-- CONSTANTS
-- ============================================

local BLOCK_SIZE = 3
local MAX_FLOW_DISTANCE = 4  -- Nether-style spread (water is 7)
local SOURCE_LEVEL = 0
local MAX_LEVEL = MAX_FLOW_DISTANCE  -- Levels 1..MAX_LEVEL are flowing
local EDGE_SEARCH_DEPTH = 4

-- Height bucket count: source = full, flowing levels divide the remaining
-- height into MAX_LEVEL+1 steps. Keep using +1 so level 1 isn't already
-- shorter than half a block at MAX_LEVEL = 4.
local HEIGHT_BUCKETS = MAX_LEVEL + 1  -- 5 with MAX_LEVEL=4 → matches water's "8 - level" feel

-- Horizontal neighbor offsets (N, S, E, W)
local HORIZONTAL_OFFSETS = {
	Vector3.new(BLOCK_SIZE, 0, 0),
	Vector3.new(-BLOCK_SIZE, 0, 0),
	Vector3.new(0, 0, BLOCK_SIZE),
	Vector3.new(0, 0, -BLOCK_SIZE),
}

local DOWN_OFFSET = Vector3.new(0, -BLOCK_SIZE, 0)
local UP_OFFSET = Vector3.new(0, BLOCK_SIZE, 0)

-- ============================================
-- UTILITY
-- ============================================

local function posKey(pos)
	local gx = math.round(pos.X / BLOCK_SIZE)
	local gy = math.round(pos.Y / BLOCK_SIZE)
	local gz = math.round(pos.Z / BLOCK_SIZE)
	return gx .. "," .. gy .. "," .. gz
end

function LavaSystem.SnapToGrid(pos, buildArea)
	if buildArea then
		local startX = buildArea:GetAttribute("TerrainStartX")
		local startZ = buildArea:GetAttribute("TerrainStartZ")
		local surfaceY = buildArea:GetAttribute("TerrainSurfaceY")
		
		if startX and startZ then
			local gx = math.round((pos.X - startX) / BLOCK_SIZE) * BLOCK_SIZE + startX
			local gz = math.round((pos.Z - startZ) / BLOCK_SIZE) * BLOCK_SIZE + startZ
			local originY = surfaceY or 0
			local gy = math.round((pos.Y - originY) / BLOCK_SIZE) * BLOCK_SIZE + originY
			return Vector3.new(gx, gy, gz)
		end
	end
	
	return Vector3.new(
		math.round(pos.X / BLOCK_SIZE) * BLOCK_SIZE,
		math.round(pos.Y / BLOCK_SIZE) * BLOCK_SIZE,
		math.round(pos.Z / BLOCK_SIZE) * BLOCK_SIZE
	)
end

function LavaSystem.GetLavaHeight(level)
	if level == SOURCE_LEVEL then
		return BLOCK_SIZE
	end
	-- (HEIGHT_BUCKETS - level) / HEIGHT_BUCKETS — same shape as water
	return BLOCK_SIZE * (HEIGHT_BUCKETS - level) / HEIGHT_BUCKETS
end

function LavaSystem.IsLava(blockType)
	return blockType == "Lava" or blockType == "LavaSource" or blockType == "LavaFlowing"
end

-- ============================================
-- TERRAIN-AWARE SOLIDITY CHECKS
-- ============================================

local function hasRealSolidBlock(pos, spatialIndex)
	if not spatialIndex then return false end
	local blocks = spatialIndex:GetBlocksAt(pos)
	for _, block in ipairs(blocks) do
		local blockType = block:GetAttribute("BlockType")
		-- Lava treats both lava AND water as non-solid (they aren't walls).
		-- Water/lava interactions are deferred to the handler layer.
		if blockType
			and not LavaSystem.IsLava(blockType)
			and blockType ~= "Water"
			and blockType ~= "WaterSource"
			and blockType ~= "WaterFlowing"
			and not block:GetAttribute("IsWater")
			and not block:GetAttribute("IsDecoration") then
			return true
		end
	end
	return false
end

local function getLavaAt(pos, spatialIndex)
	if not spatialIndex then return nil, nil end
	local blocks = spatialIndex:GetBlocksAt(pos)
	for _, block in ipairs(blocks) do
		if block:GetAttribute("IsLava") then
			local level = block:GetAttribute("LavaLevel") or 0
			return block, level
		end
	end
	return nil, nil
end

-- ============================================
-- BOUNDS CHECKS
-- ============================================

local function isInPlotBounds(pos, buildArea)
	local posX = buildArea:GetAttribute("BasePlatePositionX")
	local posY = buildArea:GetAttribute("BasePlatePositionY")
	local posZ = buildArea:GetAttribute("BasePlatePositionZ")
	local sizeX = buildArea:GetAttribute("BasePlateSizeX")
	local sizeY = buildArea:GetAttribute("BasePlateSizeY")
	local sizeZ = buildArea:GetAttribute("BasePlateSizeZ")
	
	if not (posX and posY and posZ and sizeX and sizeY and sizeZ) then
		return false
	end
	
	local halfX = sizeX / 2
	local halfZ = sizeZ / 2
	
	if pos.X < posX - halfX or pos.X > posX + halfX then return false end
	if pos.Z < posZ - halfZ or pos.Z > posZ + halfZ then return false end
	
	local plateTop = posY + sizeY / 2
	local minY = plateTop - 40 * BLOCK_SIZE - BLOCK_SIZE
	local maxY = plateTop + 400
	if pos.Y < minY or pos.Y > maxY then return false end
	
	return true
end

-- Bounds for where lava can exist. EDGE_EXTENSION = 0 means lava is strictly
-- confined to the player's plot — it cannot spill or fall past plot edges.
-- Set to BLOCK_SIZE (or larger) if you want lava to cascade past the edge
-- like a waterfall. Vertical fall depth still applies inside the plot.
local LAVA_EDGE_EXTENSION = 0
local LAVA_FALL_DEPTH = 10 * BLOCK_SIZE

local function isInLavaBounds(pos, buildArea)
	local posX = buildArea:GetAttribute("BasePlatePositionX")
	local posY = buildArea:GetAttribute("BasePlatePositionY")
	local posZ = buildArea:GetAttribute("BasePlatePositionZ")
	local sizeX = buildArea:GetAttribute("BasePlateSizeX")
	local sizeY = buildArea:GetAttribute("BasePlateSizeY")
	local sizeZ = buildArea:GetAttribute("BasePlateSizeZ")
	
	if not (posX and posY and posZ and sizeX and sizeY and sizeZ) then
		return false
	end
	
	local halfX = sizeX / 2 + LAVA_EDGE_EXTENSION
	local halfZ = sizeZ / 2 + LAVA_EDGE_EXTENSION
	
	if pos.X < posX - halfX or pos.X > posX + halfX then return false end
	if pos.Z < posZ - halfZ or pos.Z > posZ + halfZ then return false end
	
	local plateTop = posY + sizeY / 2
	local surfaceY = buildArea:GetAttribute("TerrainSurfaceY") or plateTop
	local minY = surfaceY - LAVA_FALL_DEPTH
	local maxY = plateTop + 400
	if pos.Y < minY or pos.Y > maxY then return false end
	
	return true
end

-- ============================================
-- TERRAIN SOLIDITY
-- ============================================

local SOLID_EPSILON = 0.1

local function isSolid(pos, spatialIndex, buildArea)
	if hasRealSolidBlock(pos, spatialIndex) then
		if LavaSystem._DebugFlow then
			print(string.format("[LavaSolid] (%.1f,%.1f,%.1f) SOLID (real block)", pos.X, pos.Y, pos.Z))
		end
		return true
	end
	
	if buildArea and isInPlotBounds(pos, buildArea) then
		local surfaceY = TerrainLogic.GetSurfaceYAtPosition(pos, buildArea)
		if surfaceY then
			local terrainTop = surfaceY + BLOCK_SIZE
			
			if pos.Y >= terrainTop - SOLID_EPSILON then
				if LavaSystem._DebugFlow then
					print(string.format("[LavaSolid] (%.1f,%.1f,%.1f) AIR (above terrain surfaceY=%.1f)", pos.X, pos.Y, pos.Z, surfaceY))
				end
				return false
			end
			
			-- Below the original terrain surface: terrain WOULD be here, but
			-- the player may have dug it out. Ask TerrainGenerator first.
			if LavaSystem._TerrainGenerator and LavaSystem._PlotNumberLookup then
				local plotNumber = LavaSystem._PlotNumberLookup(buildArea)
				if plotNumber then
					local isDug = LavaSystem._TerrainGenerator.IsPositionDug(pos, plotNumber, buildArea)
					if LavaSystem._DebugFlow then
						print(string.format("[LavaSolid] (%.1f,%.1f,%.1f) %s (below terrain Y=%.1f, plot=%s, dug=%s)",
							pos.X, pos.Y, pos.Z,
							isDug and "AIR" or "SOLID",
							surfaceY, tostring(plotNumber), tostring(isDug)))
					end
					if isDug then
						return false
					end
				elseif LavaSystem._DebugFlow then
					print(string.format("[LavaSolid] (%.1f,%.1f,%.1f) SOLID (plotNumber nil)", pos.X, pos.Y, pos.Z))
				end
			elseif LavaSystem._DebugFlow then
				print(string.format("[LavaSolid] (%.1f,%.1f,%.1f) SOLID (terrain hooks not set)", pos.X, pos.Y, pos.Z))
			end
			
			local surfaceBlockPos = Vector3.new(pos.X, surfaceY, pos.Z)
			if hasRealSolidBlock(surfaceBlockPos, spatialIndex) then
				return true
			end
			
			return false
		end
	end
	
	return false
end

-- ============================================
-- EDGE-SEEKING PATHFINDING
-- Same algorithm as water. See WaterSystem.luau for full explanation.
-- ============================================

local function findDropDistance(startPos, direction, spatialIndex, buildArea, flowMap)
	local searchQueue = {}
	local visited = {}
	
	local firstStep = startPos + direction
	local firstKey = posKey(firstStep)
	
	if not isInLavaBounds(firstStep, buildArea) then return nil end
	if isSolid(firstStep, spatialIndex, buildArea) then return nil end
	
	table.insert(searchQueue, { pos = firstStep, dist = 1 })
	visited[firstKey] = true
	
	local head = 1
	while head <= #searchQueue do
		local current = searchQueue[head]
		head += 1
		
		local pos = current.pos
		local dist = current.dist
		
		local belowPos = pos + DOWN_OFFSET
		if not isSolid(belowPos, spatialIndex, buildArea) then
			return dist
		end
		
		if dist < EDGE_SEARCH_DEPTH then
			for _, offset in ipairs(HORIZONTAL_OFFSETS) do
				local nextPos = pos + offset
				local nextKey = posKey(nextPos)
				
				if not visited[nextKey] then
					visited[nextKey] = true
					
					if isInLavaBounds(nextPos, buildArea) and not isSolid(nextPos, spatialIndex, buildArea) then
						table.insert(searchQueue, { pos = nextPos, dist = dist + 1 })
					end
				end
			end
		end
	end
	
	return nil
end

local function getPreferredDirections(pos, spatialIndex, buildArea, flowMap)
	local directionWeights = {}
	local minWeight = math.huge
	local hasAnyDrop = false
	
	for _, offset in ipairs(HORIZONTAL_OFFSETS) do
		local neighborPos = pos + offset
		
		if not isInLavaBounds(neighborPos, buildArea) then continue end
		if isSolid(neighborPos, spatialIndex, buildArea) then continue end
		
		local dropDist = findDropDistance(pos, offset, spatialIndex, buildArea, flowMap)
		
		if dropDist then
			hasAnyDrop = true
			table.insert(directionWeights, { direction = offset, weight = dropDist })
			if dropDist < minWeight then
				minWeight = dropDist
			end
		else
			table.insert(directionWeights, { direction = offset, weight = 1000 })
		end
	end
	
	local preferred = {}
	for _, entry in ipairs(directionWeights) do
		if not hasAnyDrop or entry.weight == minWeight then
			table.insert(preferred, entry.direction)
		end
	end
	
	return preferred
end

-- ============================================
-- FLOW CALCULATION
-- ============================================

function LavaSystem.CalculateFlow(blocksFolder, buildArea, spatialIndex)
	local flowMap = {}
	local queue = {}
	
	-- Step 1: Find all source blocks
	local sourceCount = 0
	for _, block in ipairs(blocksFolder:GetChildren()) do
		if block:GetAttribute("LavaLevel") == SOURCE_LEVEL and LavaSystem.IsLava(block:GetAttribute("BlockType")) then
			local bx = block:GetAttribute("BlockPosX")
			local by = block:GetAttribute("BlockPosY")
			local bz = block:GetAttribute("BlockPosZ")
			local pos
			if bx and by and bz then
				pos = Vector3.new(bx, by, bz)
			elseif block:IsA("BasePart") then
				pos = LavaSystem.SnapToGrid(block.Position)
			end
			
			if pos then
				local key = posKey(pos)
				flowMap[key] = { position = pos, level = SOURCE_LEVEL, isFalling = false, distance = 0 }
				table.insert(queue, { position = pos, level = SOURCE_LEVEL, isFalling = false, distance = 0 })
				sourceCount += 1
				
				-- Diagnostic: probe the cell directly below the source to see
				-- if isSolid agrees with what the player just dug. If a source
				-- is at (X, Y, Z), the cell at (X, Y-3, Z) is what lava would
				-- fall into.
				if LavaSystem._DebugFlow then
					local belowPos = pos + DOWN_OFFSET
					local belowSolid = isSolid(belowPos, spatialIndex, buildArea)
					print(string.format("[LavaFlow] Source at (%.1f,%.1f,%.1f) -- cell below (%.1f,%.1f,%.1f) isSolid=%s",
						pos.X, pos.Y, pos.Z, belowPos.X, belowPos.Y, belowPos.Z, tostring(belowSolid)))
				end
			end
		end
	end
	
	-- NOTE: No infinite-source rule for lava. Two adjacent lava sources do NOT
	-- spawn a new source between them (matches Minecraft).
	
	-- Step 2: BFS propagation with edge-seeking
	local head = 1
	local processedCount = 0
	local MAX_ITERATIONS = 50000
	
	while head <= #queue and processedCount < MAX_ITERATIONS do
		local current = queue[head]
		head += 1
		processedCount += 1
		
		local pos = current.position
		local level = current.level
		local falling = current.isFalling
		local dist = current.distance or 0
		
		local key = posKey(pos)
		local currentBest = flowMap[key]
		if currentBest and currentBest.level < level then
			continue
		end
		
		if not isInLavaBounds(pos, buildArea) then continue end
		
		-- === DOWNWARD FLOW ===
		local belowPos = pos + DOWN_OFFSET
		local belowKey = posKey(belowPos)
		local canFlowDown = false
		
		if isInLavaBounds(belowPos, buildArea) and not isSolid(belowPos, spatialIndex, buildArea) then
			canFlowDown = true
			
			local fallingLevel = 1
			
			local nextDist = dist + 1
			local existingBelow = flowMap[belowKey]
			if not existingBelow or existingBelow.level > fallingLevel then
				flowMap[belowKey] = { position = belowPos, level = fallingLevel, isFalling = true, distance = nextDist }
				table.insert(queue, { position = belowPos, level = fallingLevel, isFalling = true, distance = nextDist })
			end
		end
		
		-- === HORIZONTAL FLOW ===
		local shouldSpreadHorizontally = false
		
		if level == SOURCE_LEVEL then
			shouldSpreadHorizontally = true
		elseif not canFlowDown then
			shouldSpreadHorizontally = true
		else
			shouldSpreadHorizontally = false
		end
		
		if shouldSpreadHorizontally then
			local nextLevel
			if falling and level ~= SOURCE_LEVEL then
				nextLevel = 1
			else
				nextLevel = level + 1
			end
			
			if nextLevel <= MAX_LEVEL then
				local nextDist = dist + 1
				
				-- Minecraft lava (unlike water) does NOT edge-seek. Sources and
				-- flowing lava both spread in ALL 4 horizontal directions equally
				-- if those cells are passable. The per-cell "fall when there's air
				-- below" check (the DOWNWARD FLOW section above) handles drops
				-- independently — we don't need to steer the horizontal spread
				-- toward edges. Using edge-seeking caused the surface pool to
				-- visually shrink when a hole was dug nearby, since spread was
				-- biased toward the hole and away from the other directions.
				local directions = {}
				for _, offset in ipairs(HORIZONTAL_OFFSETS) do
					local neighborPos = pos + offset
					if isInLavaBounds(neighborPos, buildArea) and not isSolid(neighborPos, spatialIndex, buildArea) then
						table.insert(directions, offset)
					end
				end
				
				for _, offset in ipairs(directions) do
					local neighborPos = pos + offset
					local neighborKey = posKey(neighborPos)
					
					local existing = flowMap[neighborKey]
					if not existing or existing.level > nextLevel then
						flowMap[neighborKey] = { position = neighborPos, level = nextLevel, isFalling = false, distance = nextDist }
						table.insert(queue, { position = neighborPos, level = nextLevel, isFalling = false, distance = nextDist })
					end
				end
			end
		end
	end
	
	if processedCount >= MAX_ITERATIONS then
		warn("[LavaSystem] Hit max iteration limit during flow calculation!")
	end
	
	-- Debug summary
	local totalBlocks = 0
	local fallingCount = 0
	local maxDist = 0
	local levelCounts = {}
	for _, data in pairs(flowMap) do
		totalBlocks += 1
		if data.isFalling then fallingCount += 1 end
		if (data.distance or 0) > maxDist then maxDist = data.distance or 0 end
		local l = data.level
		levelCounts[l] = (levelCounts[l] or 0) + 1
	end
	local levelStr = ""
	for l = 0, MAX_LEVEL do
		if levelCounts[l] then
			levelStr = levelStr .. string.format(" L%d=%d", l, levelCounts[l])
		end
	end
	print(string.format("[LavaSystem] Flow: total=%d falling=%d maxDist=%d%s",
		totalBlocks, fallingCount, maxDist, levelStr))
	
	return flowMap
end

-- ============================================
-- FLOW DIRECTION
-- ============================================

function LavaSystem.GetFlowDirection(pos, flowMap)
	local key = posKey(pos)
	local current = flowMap[key]
	if not current then return Vector3.zero end
	
	if current.isFalling then
		return Vector3.new(0, -1, 0)
	end
	
	local flowDir = Vector3.zero
	
	for _, offset in ipairs(HORIZONTAL_OFFSETS) do
		local neighborPos = pos + offset
		local neighborKey = posKey(neighborPos)
		local neighbor = flowMap[neighborKey]
		
		local neighborLevel = neighbor and neighbor.level or (MAX_LEVEL + 1)
		
		if neighborLevel > current.level then
			flowDir = flowDir + offset.Unit
		elseif neighborLevel < current.level then
			flowDir = flowDir - offset.Unit
		end
	end
	
	if flowDir.Magnitude > 0 then
		return flowDir.Unit
	end
	return Vector3.zero
end

-- ============================================
-- VISUAL PROPERTIES
-- ============================================

function LavaSystem.GetLavaVisualProperties(level, isFalling)
	local height
	if isFalling then
		height = BLOCK_SIZE
	else
		height = LavaSystem.GetLavaHeight(level)
	end
	
	local size = Vector3.new(BLOCK_SIZE, height, BLOCK_SIZE)
	local yOffset = -BLOCK_SIZE / 2 + height / 2
	
	return {
		Size = size,
		YOffset = yOffset,
		Height = height,
		Color = Color3.fromRGB(255, 90, 20),
		Transparency = 0,  -- Fully opaque
		Material = Enum.Material.Neon,
	}
end

-- ============================================
-- CONSTANTS EXPOSED
-- ============================================

LavaSystem.BLOCK_SIZE = BLOCK_SIZE
LavaSystem.MAX_FLOW_DISTANCE = MAX_FLOW_DISTANCE
LavaSystem.SOURCE_LEVEL = SOURCE_LEVEL
LavaSystem.MAX_LEVEL = MAX_LEVEL
LavaSystem.HEIGHT_BUCKETS = HEIGHT_BUCKETS
LavaSystem.HORIZONTAL_OFFSETS = HORIZONTAL_OFFSETS
LavaSystem.DOWN_OFFSET = DOWN_OFFSET
LavaSystem.UP_OFFSET = UP_OFFSET
LavaSystem.PosKey = posKey

return LavaSystem
